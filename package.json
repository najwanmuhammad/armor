{
  "name": "arungimorotai",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev:tim": "turbo run dev --filter=web-tim",
    "dev:kolorai": "turbo run dev --filter=web-kolorai",
    "dev:yayasan": "turbo run dev --filter=web-yayasan",
    "dev:studio": "turbo run dev --filter=kkn"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
